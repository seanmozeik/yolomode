{
  "bin": {
    "yolomode": "src/cli.ts"
  },
  "dependencies": {
    "boxen": "^8.0.1",
    "console-table-printer": "^2.15.0",
    "gradient-string": "^3.0.0",
    "minimatch": "^10.2.5",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1"
  },
  "description": "Claude Code skill manager and agent runner",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.2"
  },
  "files": [
    "src",
    "package.json"
  ],
  "license": "MIT",
  "name": "yolomode",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seanmozeik/yolomode.git"
  },
  "scripts": {
    "build": "bun run scripts/build.ts compile",
    "bundle": "bun build ./src/cli.ts --outdir dist --target=bun --bytecode --minify",
    "check": "biome check --write --unsafe .",
    "dev": "bun src/cli.ts",
    "format": "biome format --write .",
    "tc": "tsc --noEmit"
  },
  "type": "module",
  "version": "0.1.0"
}
