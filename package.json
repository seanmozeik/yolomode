{
  "bin": {
    "yolomode": "src/cli.ts"
  },
  "dependencies": {
    "@opentui-ui/dialog": "^0.1.2",
    "@opentui-ui/toast": "^0.0.5",
    "@opentui/core": "^0.1.80",
    "@opentui/solid": "^0.1.80",
    "boxen": "^8.0.1",
    "console-table-printer": "^2.15.0",
    "gradient-string": "^3.0.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "solid-js": "^1.9.11"
  },
  "description": "Claude Code skill manager and agent runner",
  "devDependencies": {
    "@biomejs/biome": "^2.4.3",
    "@types/bun": "^1.3.9",
    "typescript": "^5.9.3"
  },
  "files": [
    "src",
    "package.json"
  ],
  "license": "MIT",
  "name": "yolomode",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seanmozeik/yolomode.git"
  },
  "scripts": {
    "build": "bun build --compile src/cli.ts --outfile yolomode",
    "bundle": "bun build ./src/cli.ts --outdir dist --target=bun --bytecode --minify",
    "check": "biome check --write --unsafe .",
    "dev": "bun run src/cli.ts",
    "format": "biome format --write .",
    "tc": "tsc --noEmit"
  },
  "type": "module",
  "version": "0.1.0"
}
